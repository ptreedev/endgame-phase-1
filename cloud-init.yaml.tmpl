#cloud-config
package_update: true
packages:
  - nginx
  - git
  - docker.io
  - docker-compose-v2

write_files:
  - path: /etc/nginx/sites-available/my-site.conf
    permissions: '0644'
    content: |
      server {
        listen 80;
        server_name _;

        location / {
            proxy_pass http://127.0.0.1:8080;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
      }

runcmd:
  # Nginx setup
  - ln -s /etc/nginx/sites-available/my-site.conf /etc/nginx/sites-enabled/
  - rm /etc/nginx/sites-enabled/default
  - systemctl restart nginx

  # Docker setup
  - systemctl start docker
  - systemctl enable docker
  - usermod -aG docker ubuntu

  # Clone the repo as the ubuntu user so ownership is correct from the start
  # This avoids the "dubious ownership" git error in the deploy pipeline
  - sudo -u ubuntu git clone https://github.com/ptreedev/endgame-phase-1 /home/ubuntu/endgame-phase-1

  # Ensure the entire directory is owned by ubuntu, not root
  - chown -R ubuntu:ubuntu /home/ubuntu/endgame-phase-1

  - |
    cat > /home/ubuntu/endgame-phase-1/.env << 'EOF'
    DB_HOST=${DB_HOST}
    DB_USERNAME=${DB_USERNAME}
    DB_PASSWORD=${DB_PASSWORD}
    DB_NAME=${DB_NAME}
    DB_PORT=${DB_PORT}
    EOF
  - chmod 600 /home/ubuntu/endgame-phase-1/.env
  - chown ubuntu:ubuntu /home/ubuntu/endgame-phase-1/.env

  - cd /home/ubuntu/endgame-phase-1 && docker compose up -d --build

 
